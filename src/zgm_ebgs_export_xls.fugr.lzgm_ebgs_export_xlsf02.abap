*----------------------------------------------------------------------*
***INCLUDE LZGM_EBGS_EXPORT_XLSF02.
*----------------------------------------------------------------------*
*&---------------------------------------------------------------------*
*& Form CONVERT_CHAR_TO_DATM
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM convert_char_to_datm USING p_in CHANGING p_out.

  DATA:
lv_p_in TYPE char10.

    CHECK p_in IS NOT INITIAL.
    IF p_in(1) CA sy-abcde.
      p_out = p_in.
    ELSE.
      CLEAR: p_out.
      CONCATENATE p_in+6(4) p_in+3(2) p_in(2) INTO p_out.
    ENDIF.
ENDFORM.
